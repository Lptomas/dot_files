
[cursor]
unfocused_hollow = false

[cursor.style]
blinking = "On"
shape = "Beam"

[env]
TERM = "xterm-256color"
WINIT_X11_SCALE_FACTOR = "1.2"

[window]
opacity = 1.0

[scrolling]
history = 10000
multiplier = 3

[general]
live_config_reload = true
import = ["~/.config/alacritty/colors.toml", "~/.config/alacritty/fonts.toml"]

[window.dimensions]
columns = 80
lines = 24
